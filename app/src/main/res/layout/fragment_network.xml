<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Content (shown when permission granted) ── -->
    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Global speed card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:layout_margin="12dp"
            android:padding="14dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="İNDİRME"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvGlobalRx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B/s"
                    android:textColor="@color/accent_green"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/text_secondary"
                android:alpha="0.3" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YÜKLEME"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvGlobalTx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 B/s"
                    android:textColor="@color/accent_orange"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑"
                    android:textColor="@color/accent_orange"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tab toggle: Canlı / 24 Saat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/card_bg"
            android:padding="4dp">

            <Button
                android:id="@+id/btnTabLive"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="🔴 Canlı"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:singleLine="true"
                android:ellipsize="end"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="#000000"
                android:backgroundTint="@color/accent_cyan" />

            <Button
                android:id="@+id/btnTab24h"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="📊 24 Saat"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:singleLine="true"
                android:ellipsize="end"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@color/surface_dark" />
        </LinearLayout>

        <!-- ── Live tab ── -->
        <LinearLayout
            android:id="@+id/layoutLive"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLiveEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="@string/live_traffic_empty"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerLive"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ── 24h tab ── -->
        <LinearLayout
            android:id="@+id/layout24h"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:paddingTop="4dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:text="0 uygulama" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnRefresh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yenile"
                    android:textSize="12sp"
                    android:backgroundTint="@color/accent_cyan"
                    android:textColor="#000000" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:text="@string/network_info"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/network_empty"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="8dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Permission screen ── -->
    <LinearLayout
        android:id="@+id/layoutPermission"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="56sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/network_perm_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/network_perm_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnGrantPermission"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/perm_button"
            android:textSize="15sp"
            android:textColor="#000000"
            android:backgroundTint="@color/accent_cyan" />
    </LinearLayout>

</FrameLayout>
